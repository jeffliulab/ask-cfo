# ask-cfo 环境变量样例（按 agent-rules / GLOBAL.md：.env 不入 git，.env.example 入 git）
# 用法：cp .env.example .env，再填入真实值

# === LLM 选择 + API Keys（与 fin-pilot 共用 4 provider 矩阵） ===
# 选一个 provider；不写 *_MODEL 用 orchestrator 内置默认 model
LLM_PROVIDER=anthropic                          # 默认 model: claude-3-5-sonnet-latest

# Anthropic Claude（默认）
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-3-opus-latest          # 可选

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-proj-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.together.xyz/v1   # 可选，OpenAI 兼容端点

# DeepSeek（中文 + 便宜，CFO 场景推荐）
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-reasoner

# Ollama 本地
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b                        # 中文场景 qwen / yi 系列效果好

# === CFO 模块数据源（按需启用） ===
# OCR provider（凭证录入；v0.1 决定后填）
# AZURE_DOCUMENT_INTELLIGENCE_KEY=
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# TENCENT_OCR_SECRET_ID=
# TENCENT_OCR_SECRET_KEY=

# 法规 RAG 数据源（v0.1 决定后填）
# REGULATIONS_DB_PATH=./data/regulations.db
# QDRANT_URL=
# QDRANT_API_KEY=

# === 运行时 ===
LOG_LEVEL=INFO
LOG_FILE=logs/ask-cfo.log

# === CORS（前端 dev 服务器地址；多个用逗号分隔） ===
CORS_ORIGINS=http://localhost:3000
